# ── 서버사이드 전용 키 (VITE_ 접두사 없음 → 클라이언트 번들에 포함되지 않음) ─
# Vercel Edge Function / Vite dev 미들웨어가 프록시로 사용

# OpenWeatherMap - https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here

# Finnhub Stock API - https://finnhub.io
FINNHUB_API_KEY=your_key_here

# Gemini - https://aistudio.google.com/apikey
# 무료 tier: 분당 15회 / 일 1,500회
GEMINI_API_KEY=your_key_here

# Upstash Redis - https://console.upstash.com
# /api/chat rate limit (IP당 분당 10회). 미설정 시 dev에서는 enforcement 생략됨.
# 프로덕션 배포 시 반드시 설정 권장 — 미설정이면 봇이 Gemini 쿼터를 폭격할 수 있음.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── 클라이언트에 공개되는 값 (Supabase는 RLS로 보호되므로 공개 OK) ─

# Supabase - https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# (선택) OAuth redirect 고정 도메인. 미설정 시 현재 origin 사용.
# Vercel preview URL에서 prod로 잘못 리다이렉트되는 것을 막고 싶을 때 prod 도메인으로 고정.
# Supabase Dashboard → Authentication → URL Configuration 에 동일 URL을 화이트리스트에 등록해야 함.
# VITE_SITE_URL=https://your-domain.com

# ── 웹 푸시 알림 (일정 리마인더) ─
# VAPID 키 생성: npx web-push generate-vapid-keys --json
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key   # 클라이언트 구독용 (공개 OK)
VAPID_PUBLIC_KEY=your_vapid_public_key        # 서버 발송용 (공개키와 동일)
VAPID_PRIVATE_KEY=your_vapid_private_key      # 서버 전용 비밀키
VAPID_SUBJECT=mailto:you@example.com          # VAPID 연락처 (mailto: 또는 https URL)

# 발송 함수가 전체 사용자 일정을 조회하는 데 필요 (RLS 우회).
# Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Vercel Cron 호출 인증용 랜덤 문자열.
CRON_SECRET=your_random_secret
